int[] marks = {80, 75, 90, 65, 85};

int sum = 0;
int highest = marks[0];
int lowest = marks[0];

for (int i = 0; i < marks.length; i++) {
    sum += marks[i];

    if (marks[i] > highest)
        highest = marks[i];

    if (marks[i] < lowest)
        lowest = marks[i];
}

double average = (double) sum / marks.length;

System.out.println("Average = " + average);
System.out.println("Highest = " + highest);
System.out.println("Lowest = " + lowest);
